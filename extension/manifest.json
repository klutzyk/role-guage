{
  "manifest_version": 3,
  "name": "RoleGuage Resume & Job Matcher",
  "version": "1.0.4",
  "description": "Analyze the current job page or selected job text against your resume and get fit insights.",
  "permissions": ["activeTab", "scripting", "storage"],
  
  "host_permissions": ["https://roleguage.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "RoleGuage",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
